# 前端配置模板
# 用法：复制为 .env（cp .env.example .env），按部署环境填值。

# ── 后端 API 基础地址（前端发请求的目标）──
# 改后端端口/换部署机器时，改这一行即可，无需动代码。
# 注意：Vite 只认 VITE_ 前缀的变量注入到 import.meta.env。
VITE_API_BASE=http://127.0.0.1:8000

# ── Vite base 路径（资源 URL 前缀）──
#   · 本地直接访问 http://localhost:5173        → 填 /
#   · 远程平台反代 https://<域名>/proxy/5173/   → 填 /proxy/5173/
#     （否则浏览器按绝对路径请求 /src/main.jsx 会丢前缀 → 404 → 白屏）
BASE_URL=/
