# ──────────────────────────────────────────────────────────
# 攻防评测统一服务配置模板
# 用法：复制本文件为 .env（cp .env.example .env），把下面的地址改成你自己的服务地址。
# 规则：shell 已导出的同名环境变量优先，本文件不覆盖。
# ──────────────────────────────────────────────────────────

# ── 服务运行 ──
SERVER_PORT=8000                   # 统一服务端口（攻击评测 + 防御检测共用）
PRELOAD=true                       # 启动是否预热 low 档 BERT 检测器
MAX_CONCURRENT_DETECT=12           # 同时进行的 BERT 输入检测数（并发闸门）
DETECT_QUEUE_TIMEOUT=120           # BERT 检测排队等待超时（秒）
LLM_TIMEOUT=60                     # LLM 调用超时（秒）

# ── 后端大模型（被攻击的目标模型）──
LLM_SERVER_URL=http://127.0.0.1:8000/v1
LLM_SERVER_MODEL=Qwen3

# ── 模盾·输入检测 LLM（BERT 不确定时回退复审）──
INPUT_DETECTOR_API_URL=http://127.0.0.1:8094/v1/chat/completions
INPUT_DETECTOR_API_MODEL=Qwen3-input

# ── 模盾·输出检测 LLM（宪法规则裁判）──
OUTPUT_DETECTOR_API_URL=http://127.0.0.1:8095/v1
OUTPUT_DETECTOR_MODEL=Qwen_output

# ── Embedding 服务（仅 enable_rag=true 时使用）──
EMBEDDING_API_URL=http://127.0.0.1:8096/v1/embeddings
EMBEDDING_MODEL=embedding-model

# ── 判题 API（DeepSeek 裁判模型，攻击赛道判题用）──
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── 本地服务绕过代理（127.x 走直连，不经系统代理）──
# 若模型服务在内网，把对应 IP/域名加进来
NO_PROXY=127.0.0.1,localhost
no_proxy=127.0.0.1,localhost
