# ───────── 依赖目录（npm install / pip install 重新生成）─────────
node_modules/
frontend/node_modules/

# ───────── 构建产物 ─────────
frontend/dist/
frontend/.vite/
dist/
build/

# ───────── Python 缓存与产物 ─────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
*.so

# ───────── 虚拟环境 ─────────
.venv/
venv/
env/
ENV/

# ───────── 敏感配置（.env 含本地部署地址，不入库；用 .env.example 作模板）─────────
.env
*.env.local
backend/.env
frontend/.env

# ───────── 运行时生成的数据/模型缓存（首次运行自动下载或生成）─────────
backend/data/adv_corpus.pt
backend/models/

# ───────── 日志与临时文件 ─────────
*.log
logs/
*.tmp
*.swp
*.bak

# ───────── 打包压缩包（分发产物）─────────
*.zip
*.7z
*.tar.gz

# ───────── 编辑器 / IDE / 系统 ─────────
.vscode/
.idea/
*.code-workspace
.DS_Store
Thumbs.db
desktop.ini

# ───────── 测试 / 覆盖率 ─────────
.coverage
htmlcov/
.pytest_cache/
.cache/

# ───────── ZCode / Agent 本地工作目录（非项目代码）─────────
.codex/
.agents/
